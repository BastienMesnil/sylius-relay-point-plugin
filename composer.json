{
    "name": "keirontw/sylius-relay-point-plugin",
    "type": "sylius-plugin",
    "description": "Carrier-agnostic relay point (point relais) selection plugin for Sylius 1.9+ checkout",
    "keywords": [
        "sylius",
        "sylius-plugin",
        "relay-point",
        "point-relais",
        "mondial-relay",
        "chronopost",
        "colissimo",
        "inpost",
        "pickup",
        "checkout"
    ],
    "license": "MIT",
    "require": {
        "php": "^8.1",
        "ext-soap": "*",
        "sylius/sylius": "^1.9",
        "symfony/http-client": "^5.4 || ^6.0"
    },
    "require-dev": {
        "behat/behat": "^3.16",
        "dbrekelmans/bdi": "^1.4",
        "dmore/behat-chrome-extension": "^1.4",
        "dmore/chrome-mink-driver": "^2.9",
        "friends-of-behat/mink": "^1.11",
        "friends-of-behat/mink-browserkit-driver": "^1.6",
        "friends-of-behat/mink-debug-extension": "^2.1",
        "friends-of-behat/mink-extension": "^2.7",
        "friends-of-behat/page-object-extension": "^0.3",
        "friends-of-behat/suite-settings-extension": "^1.1",
        "friends-of-behat/symfony-extension": "^2.6",
        "friends-of-behat/variadic-extension": "^1.6",
        "nyholm/psr7": "^1.8",
        "phpstan/phpstan": "^2.0",
        "phpstan/phpstan-doctrine": "^2.0",
        "phpstan/phpstan-webmozart-assert": "^2.0",
        "phpunit/phpunit": "^10.5",
        "sylius-labs/coding-standard": "^4.4",
        "sylius-labs/suite-tags-extension": "~0.2",
        "symfony/browser-kit": "^5.4 || ^6.0",
        "symfony/debug-bundle": "^5.4 || ^6.0",
        "symfony/dotenv": "^5.4 || ^6.0",
        "symfony/intl": "^5.4 || ^6.0",
        "symfony/runtime": "^5.4 || ^6.0",
        "symfony/web-profiler-bundle": "^5.4 || ^6.0",
        "symfony/webpack-encore-bundle": "^2.2"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "dealerdirect/phpcodesniffer-composer-installer": false,
            "php-http/discovery": false,
            "phpstan/extension-installer": true,
            "symfony/flex": true,
            "symfony/runtime": true
        }
    },
    "extra": {
        "branch-alias": {
            "dev-1.x": "1.0-dev"
        },
        "symfony": {
            "require": "^5.4 || ^6.0"
        }
    },
    "autoload": {
        "psr-4": {
            "Keirontw\\SyliusRelayPointPlugin\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\Keirontw\\SyliusRelayPointPlugin\\": [
                "tests/",
                "tests/TestApplication/src/"
            ]
        }
    },
    "scripts": {
        "test": "vendor/bin/phpunit"
    }
}
