<?xml version="1.0" encoding="UTF-8" ?>

<container
        xmlns="http://symfony.com/schema/dic/services"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://symfony.com/schema/dic/services http://symfony.com/schema/dic/services/services-1.0.xsd"
>
    <services>
        <instanceof id="Keirontw\SyliusRelayPointPlugin\RelayPoint\RelayPointProviderInterface" autoconfigure="true">
            <tag name="keirontw_sylius_relay_point.relay_point_provider" />
        </instanceof>

        <service id="Keirontw\SyliusRelayPointPlugin\RelayPoint\RelayPointRegistry">
            <argument type="tagged_iterator" tag="keirontw_sylius_relay_point.relay_point_provider" />
        </service>
        <service id="Keirontw\SyliusRelayPointPlugin\RelayPoint\RelayPointRegistryInterface" alias="Keirontw\SyliusRelayPointPlugin\RelayPoint\RelayPointRegistry" />

        <service id="Keirontw\SyliusRelayPointPlugin\RelayPoint\RelayPointSearchService" public="true">
            <argument type="service" id="Keirontw\SyliusRelayPointPlugin\RelayPoint\RelayPointRegistryInterface" />
        </service>
        <service id="Keirontw\SyliusRelayPointPlugin\RelayPoint\RelayPointSearchServiceInterface" alias="Keirontw\SyliusRelayPointPlugin\RelayPoint\RelayPointSearchService" public="true" />

        <service id="Keirontw\SyliusRelayPointPlugin\Controller\Shop\RelayPointSearchController" public="true">
            <argument type="service" id="Keirontw\SyliusRelayPointPlugin\RelayPoint\RelayPointSearchServiceInterface" />
            <argument type="service" id="Keirontw\SyliusRelayPointPlugin\Geocoding\GeocodingProviderInterface" />
            <call method="setContainer">
                <argument type="service" id="service_container" />
            </call>
            <tag name="controller.service_arguments" />
        </service>
    </services>
</container>
